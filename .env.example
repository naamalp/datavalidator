# Twilio Lookup Identity Match
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Optional: port for the app (default 3000)
# PORT=3000

# --- Testing without API cost (mocks) ---
# Redirect all Twilio requests to a Prism mock server (e.g. http://127.0.0.1:4010).
# See: https://www.twilio.com/docs/openapi/mock-api-generation-with-twilio-openapi-spec
# TWILIO_MOCK_BASE_URL=http://127.0.0.1:4010

# Use inline mock for Caller Name (Find names): returns fake caller names, no Twilio Caller Name API calls.
# Set to 1, true, or yes to enable. Useful for testing the Find names feature without cost.
# TWILIO_MOCK_CALLER_NAME=1
