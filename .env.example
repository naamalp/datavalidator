# Twilio Lookup Identity Match
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Optional: port for the app (default 3000)
# PORT=3000

# App login users (no signup flow). Format: comma-separated username:password pairs.
# Example: AUTH_USERS=admin:change-me,ops:another-password
AUTH_USERS=naaman@alperformance.co.uk:Dopper-12

# --- Testing without API cost (mocks) ---
# Redirect all Twilio requests to a Prism mock server (e.g. http://127.0.0.1:4010).
# See: https://www.twilio.com/docs/openapi/mock-api-generation-with-twilio-openapi-spec
# TWILIO_MOCK_BASE_URL=http://127.0.0.1:4010

# Use inline mock for Identity Match (chunked processing): returns fake match values, no Twilio Identity Match API calls.
# Set to 1, true, or yes to enable.
# TWILIO_MOCK_IDENTITY_MATCH=1

# Bounded concurrency for Identity Match inside /api/process-chunk.
# Start at 8 and increase until 429/timeouts rise, then step back.
# IDENTITY_MATCH_CONCURRENCY=8

# Use inline mock for Caller Name (Find names): returns fake caller names, no Twilio Caller Name API calls.
# Set to 1, true, or yes to enable.
# TWILIO_MOCK_CALLER_NAME=1
